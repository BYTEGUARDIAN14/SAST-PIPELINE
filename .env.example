# ═══════════════════════════════════════════════════════════════
# SAST Pipeline — Environment Variables
# Author: Mohamed Adhnaan J M | BYTEAEGIS (byteaegis.in)
#
# Copy this file to .env and fill in the values.
# ═══════════════════════════════════════════════════════════════

# Flask environment mode (development / production)
FLASK_ENV=development

# Flask secret key for session security
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Database connection string (SQLite by default)
DATABASE_URL=sqlite:///findings.db

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Slack incoming webhook URL for critical finding alerts (optional)
# Create one at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Enable or disable Slack notifications
SLACK_ENABLED=true

# Frontend API base URL (used at build time by Vite)
VITE_API_URL=http://localhost:5000
